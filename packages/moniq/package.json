{
  "name": "moniq",
  "version": "0.0.0",
  "description": "Policy-driven workspace linter for JavaScript/TypeScript monorepos",
  "type": "module",
  "license": "MIT",
  "author": "Udoh Jeremiah",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "moniq": "./dist/cli.js"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/udohjeremiah/moniq.git"
  },
  "keywords": [
    "workspace",
    "monorepo",
    "Turborepo",
    "Nx",
    "cli",
    "policy",
    "linter"
  ],
  "bugs": {
    "url": "https://github.com/udohjeremiah/moniq/issues"
  },
  "homepage": "https://github.com/udohjeremiah/moniq#readme",
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint --fix .",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@moniq/cli": "workspace:*",
    "@moniq/config": "workspace:*",
    "@moniq/eslint-config": "workspace:*",
    "@moniq/typescript-config": "workspace:*",
    "@types/node": "^26.1.1",
    "eslint": "^10.6.0",
    "shell-quote": "^1.9.0",
    "tsdown": "^0.22.4",
    "vitest": "^4.1.10"
  }
}
