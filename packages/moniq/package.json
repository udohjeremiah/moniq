{
  "name": "@udohjeremiah/moniq",
  "version": "0.5.0",
  "description": "Policy-driven workspace linter for JavaScript/TypeScript monorepos",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Udoh Jeremiah",
    "email": "hello@udohjeremiah.com",
    "url": "https://udohjeremiah.com"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist/"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "moniq": "./dist/cli.js"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/udohjeremiah/moniq.git",
    "directory": "packages/moniq"
  },
  "keywords": [
    "workspace",
    "monorepo",
    "Turborepo",
    "Nx",
    "cli",
    "policy",
    "linter"
  ],
  "bugs": {
    "url": "https://github.com/udohjeremiah/moniq/issues"
  },
  "homepage": "https://udohjeremiah.github.io/moniq",
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint --fix .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepack": "cp ../../README.md README.md && cp ../../LICENSE LICENSE"
  },
  "devDependencies": {
    "@moniq/cli": "workspace:*",
    "@moniq/config": "workspace:*",
    "@moniq/eslint-config": "workspace:*",
    "@moniq/typescript-config": "workspace:*",
    "shell-quote": "^1.9.0",
    "tsdown": "^0.22.4",
    "vitest": "^4.1.10"
  }
}
